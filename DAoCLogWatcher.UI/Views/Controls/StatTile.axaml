<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:DAoCLogWatcher.UI.Views.Controls"
             x:Class="DAoCLogWatcher.UI.Views.Controls.StatTile"
             x:DataType="controls:StatTile"
             x:Name="self">
    <Border Background="{DynamicResource AppWindowBackground}"
            BorderBrush="{DynamicResource AppRowBorder}" BorderThickness="1"
            CornerRadius="6" Padding="12,14">
        <StackPanel Spacing="4">
            <TextBlock Text="{Binding #self.Label}" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextMuted}" />
            <TextBlock Text="{Binding #self.Value}" FontSize="24" FontWeight="Bold"
                       Foreground="{Binding #self.ValueColor}" />
        </StackPanel>
    </Border>
</UserControl>