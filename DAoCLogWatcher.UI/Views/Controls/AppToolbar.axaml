<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DAoCLogWatcher.UI.ViewModels"
             x:Class="DAoCLogWatcher.UI.Views.Controls.AppToolbar"
             x:DataType="vm:MainWindowViewModel">

    <Border Background="{DynamicResource AppPanelBackground}" Padding="15" Margin="0,0,0,10">
        <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" ClipToBounds="True">
                <Button Content="Open DAoC Log"
                        Command="{Binding OpenDaocLogCommand}"
                        Background="#FF007ACC"
                        Foreground="White"
                        Padding="12,8"
                        CornerRadius="6"
                        BorderThickness="0" />
                <Button Content="Open Log File"
                        Command="{Binding OpenFileCommand}"
                        CommandParameter="{Binding $parent[Window].StorageProvider}"
                        Background="#FF007ACC"
                        Foreground="White"
                        Padding="12,8"
                        CornerRadius="6"
                        BorderThickness="0" />
                <Button Content="Browse Sessions"
                        Command="{Binding OpenSessionPickerCommand}"
                        CommandParameter="{Binding $parent[Window]}"
                        Background="#FF007ACC"
                        Foreground="White"
                        Padding="12,8"
                        CornerRadius="6"
                        BorderThickness="0" />
                <Button Content="Stop Watching"
                        Command="{Binding StopWatchingCommand}"
                        IsEnabled="{Binding IsWatching}"
                        Background="#FFDC3545"
                        Foreground="White"
                        Padding="12,8"
                        CornerRadius="6"
                        BorderThickness="0" />
                <Button Content="📷"
                        Click="OnScreenshotButtonClick"
                        ToolTip.Tip="Copy screenshot to clipboard"
                        Background="#FF555566"
                        Foreground="White"
                        Padding="12,8"
                        CornerRadius="6"
                        BorderThickness="0" />
                <Button Content="{Binding ThemeIcon}"
                        Command="{Binding ToggleThemeCommand}"
                        Background="#FF555566"
                        Foreground="White"
                        Padding="12,8"
                        CornerRadius="6"
                        BorderThickness="0" />
                <ComboBox SelectedIndex="{Binding TimeFilter.SelectedTimeFilterIndex}"
                          VerticalAlignment="Center"
                          Margin="20,0,0,0"
                          MinWidth="120">
                    <ComboBoxItem Content="All time" />
                    <ComboBoxItem Content="Last 1 week" />
                    <ComboBoxItem Content="Last 48h" />
                    <ComboBoxItem Content="Last 24h" />
                    <ComboBoxItem Content="Last 12h" />
                    <ComboBoxItem Content="Last 6h" />
                    <ComboBoxItem Content="Last 3h" />
                    <ComboBoxItem Content="Last 2h" />
                    <ComboBoxItem Content="Last 1h" />
                    <ComboBoxItem Content="Custom…" />
                </ComboBox>
                <TextBlock Text="{Binding CurrentFilePath}"
                           Foreground="{DynamicResource AppTextMuted}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0" />
                <TextBlock Text="Parsing..."
                           FontSize="12"
                           Foreground="#FF00D9FF"
                           VerticalAlignment="Center"
                           IsVisible="{Binding IsParsing}" />
                <ProgressBar IsIndeterminate="True"
                             Height="4"
                             Width="120"
                             VerticalAlignment="Center"
                             Foreground="#FF00D9FF"
                             IsVisible="{Binding IsParsing}" />
            </StackPanel>
            <Button Grid.Column="1"
                    Command="{Binding ToggleSettingsPopupCommand}"
                    ToolTip.Tip="Settings"
                    Background="#FF555566"
                    Foreground="White"
                    Padding="10,8"
                    CornerRadius="6"
                    BorderThickness="0"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center">
                <Viewbox Width="16" Height="16">
                    <Path Fill="White"
                          Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" />
                </Viewbox>
            </Button>
        </Grid>
    </Border>
</UserControl>