<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DAoCLogWatcher.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:tabs="using:DAoCLogWatcher.UI.Views.Tabs"
        xmlns:viewcontrols="using:DAoCLogWatcher.UI.Views.Controls"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="DAoCLogWatcher.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/logo.ico"
        Title="DAoC Log Watcher"
        Width="1535" Height="1268"
        Background="{DynamicResource AppWindowBackground}"
        Classes.highlight-multikills="{Binding HighlightMultiKills}"
        Classes.highlight-multihits="{Binding HighlightMultiHits}">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Window.highlight-multikills Border.multikill">
            <Setter Property="Background" Value="#44FFAA00" />
            <Setter Property="BorderBrush" Value="#FFAA00" />
            <Setter Property="BorderThickness" Value="3,2,0,2" />
        </Style>
        <Style Selector="Window.highlight-multikills Border.multikill TextBlock.source-label">
            <Setter Property="Foreground" Value="#FFFFAA00" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style Selector="Window.highlight-multihits Border.multihit">
            <Setter Property="Background" Value="#44CC44FF" />
            <Setter Property="BorderBrush" Value="#CC44FF" />
            <Setter Property="BorderThickness" Value="3,2,0,2" />
        </Style>
    </Window.Styles>

    <Panel>
        <Grid RowDefinitions="Auto,*">
            <viewcontrols:AppToolbar Grid.Row="0" x:Name="Toolbar" />

            <Grid x:Name="MainContentGrid" Grid.Row="1" ColumnDefinitions="320,*" Margin="10,0,10,10">
                <viewcontrols:SummarySidebar Grid.Column="0" />

                <Border Grid.Column="1" Background="{DynamicResource AppPanelBackground}"
                        BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="8"
                        Padding="10" Margin="0,0,0,0">
                    <TabControl>

                        <TabItem Header="Realm Points" IsVisible="{Binding RealmPointsTab.Value}">
                            <tabs:RealmPointsTabView />
                        </TabItem>

                        <TabItem Header="Combat" IsVisible="{Binding CombatTab.Value}">
                            <tabs:CombatTabView />
                        </TabItem>

                        <TabItem Header="Heal Log" IsVisible="{Binding HealLogTab.Value}">
                            <tabs:HealLogTabView />
                        </TabItem>

                        <TabItem Header="Combat Log" IsVisible="{Binding CombatLogTab.Value}">
                            <tabs:CombatLogTabView />
                        </TabItem>

                        <TabItem Header="Kill Zones" IsVisible="{Binding ZoneKillsTab.Value}">
                            <tabs:KillZonesTabView />
                        </TabItem>

                        <TabItem Header="Kill Heatmap" IsVisible="{Binding KillHeatmapTab.Value}">
                            <tabs:KillHeatmapTabView />
                        </TabItem>

                    </TabControl>
                </Border>
            </Grid>
        </Grid>

        <!-- Sidebar reopen strip (visible only when sidebar is collapsed) -->
        <Button IsVisible="{Binding !IsSidebarVisible}"
                Command="{Binding ToggleSidebarCommand}"
                Content="▶"
                HorizontalAlignment="Left" VerticalAlignment="Center"
                Margin="0"
                Background="#FF336655" Foreground="White"
                Padding="4,20" BorderThickness="0"
                CornerRadius="0,6,6,0"
                ToolTip.Tip="Show Summary" />

        <!-- Update available popup -->
        <Border IsVisible="{Binding IsUpdateAvailable}"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,30,30"
                Background="{DynamicResource AppCardBackground}"
                BorderBrush="#FF28A745" BorderThickness="1"
                CornerRadius="8" Padding="16,12"
                BoxShadow="0 4 20 0 #88000000">
            <StackPanel Spacing="10" Width="260">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Update Available" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{DynamicResource AppTextPrimary}" />
                        <TextBlock Text="{Binding UpdateVersionText}" FontSize="12"
                                   Foreground="#FF28A745" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="✕"
                            Command="{Binding DismissUpdateCommand}"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource AppTextMuted}"
                            Padding="6,2" FontSize="12"
                            VerticalAlignment="Top" />
                </Grid>
                <Button Content="Update"
                        Command="{Binding ApplyUpdateAndRestartCommand}"
                        Background="#FF28A745" Foreground="White"
                        Padding="10,7" CornerRadius="5" BorderThickness="0"
                        HorizontalAlignment="Stretch" />
            </StackPanel>
        </Border>

        <!-- Custom time filter popup -->
        <Border IsVisible="{Binding TimeFilter.IsCustomPopupVisible}"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="340,55,0,0"
                Background="{DynamicResource AppCardBackground}"
                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="16,14"
                BoxShadow="0 4 20 0 #88000000">
            <StackPanel Spacing="12" Width="220">
                <TextBlock Text="Custom time window"
                           FontWeight="SemiBold" FontSize="13"
                           Foreground="{DynamicResource AppTextPrimary}" />
                <Grid ColumnDefinitions="*,12,*">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Hours" FontSize="11" Foreground="{DynamicResource AppTextMuted}" />
                        <NumericUpDown Value="{Binding TimeFilter.CustomInputHours}"
                                       Minimum="0" Maximum="9999"
                                       Increment="1" FormatString="0"
                                       ClipValueToMinMax="True" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                        <TextBlock Text="Minutes" FontSize="11" Foreground="{DynamicResource AppTextMuted}" />
                        <NumericUpDown Value="{Binding TimeFilter.CustomInputMinutes}"
                                       Minimum="0" Maximum="59"
                                       Increment="5" FormatString="0"
                                       ClipValueToMinMax="True" />
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Apply"
                            Command="{Binding TimeFilter.ApplyCustomFilterCommand}"
                            Background="#FF00D9FF" Foreground="#FF1A1A2E"
                            Padding="14,7" CornerRadius="5" BorderThickness="0"
                            FontWeight="SemiBold" />
                    <Button Content="Cancel"
                            Command="{Binding TimeFilter.CancelCustomFilterCommand}"
                            Background="Transparent"
                            Foreground="{DynamicResource AppTextMuted}"
                            Padding="10,7" CornerRadius="5" BorderThickness="1"
                            BorderBrush="{DynamicResource AppBorderBrush}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Send notification toast -->
        <Border IsVisible="{Binding SendNotification.IsVisible}"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,20,20"
                Background="#DD1E1E2E"
                BorderBrush="#FF00D9FF" BorderThickness="1"
                CornerRadius="8" Padding="14,10"
                BoxShadow="0 4 20 0 #88000000">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="2">
                    <TextBlock Text="{Binding SendNotification.Sender}"
                               Foreground="#FF00D9FF" FontWeight="SemiBold" FontSize="13" />
                    <TextBlock Text="{Binding SendNotification.Message}"
                               Foreground="{DynamicResource AppTextPrimary}" FontSize="12"
                               TextWrapping="Wrap" MaxWidth="300" />
                </StackPanel>
                <Button Grid.Column="1" Content="✕"
                        Command="{Binding SendNotification.DismissCommand}"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource AppTextMuted}"
                        Padding="6,2" FontSize="11"
                        VerticalAlignment="Top" Margin="8,0,0,0" />
            </Grid>
        </Border>

        <!-- Settings popup -->
        <Border IsVisible="{Binding IsSettingsPopupVisible}"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,55,10,0"
                Background="{DynamicResource AppCardBackground}"
                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="16,14"
                BoxShadow="0 4 20 0 #88000000">
            <StackPanel Spacing="12" Width="300">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Settings"
                               FontWeight="SemiBold" FontSize="13"
                               Foreground="{DynamicResource AppTextPrimary}"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="✕"
                            Command="{Binding CloseSettingsPopupCommand}"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource AppTextMuted}"
                            Padding="6,2" FontSize="12"
                            VerticalAlignment="Top" />
                </Grid>
                <Rectangle Fill="{DynamicResource AppBorderBrush}" Height="1" />
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Highlight Multi-Kills"
                                   Foreground="{DynamicResource AppTextPrimary}" FontSize="12" />
                        <TextBlock Text="Amber border on multi-kill RP entries"
                                   Foreground="{DynamicResource AppTextMuted}" FontSize="10" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1"
                                  IsChecked="{Binding HighlightMultiKills}"
                                  OffContent="" OnContent=""
                                  VerticalAlignment="Center" />
                </Grid>
                <Rectangle Fill="{DynamicResource AppBorderBrush}" Height="1" />
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Highlight AoE Multi-Hits"
                                   Foreground="{DynamicResource AppTextPrimary}" FontSize="12" />
                        <TextBlock Text="Purple border on AoE aggregate combat log entries"
                                   Foreground="{DynamicResource AppTextMuted}" FontSize="10" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1"
                                  IsChecked="{Binding HighlightMultiHits}"
                                  OffContent="" OnContent=""
                                  VerticalAlignment="Center" />
                </Grid>
                <Rectangle Fill="{DynamicResource AppBorderBrush}" Height="1" />
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Send Notifications"
                                   Foreground="{DynamicResource AppTextPrimary}" FontSize="12" />
                        <TextBlock Text="Show toast when a player sends a message"
                                   Foreground="{DynamicResource AppTextMuted}" FontSize="10" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1"
                                  IsChecked="{Binding ShowSendNotifications}"
                                  OffContent="" OnContent=""
                                  VerticalAlignment="Center" />
                </Grid>
                <Rectangle Fill="{DynamicResource AppBorderBrush}" Height="1" />
                <TextBlock Text="TABS" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource AppTextMuted}" />
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Realm Points Tab" Foreground="{DynamicResource AppTextPrimary}" FontSize="12" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding RealmPointsTab.Value}"
                                  OffContent="" OnContent="" VerticalAlignment="Center" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Combat Stats Tab" Foreground="{DynamicResource AppTextPrimary}" FontSize="12" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding CombatTab.Value}"
                                  OffContent="" OnContent="" VerticalAlignment="Center" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Heal Log Tab" Foreground="{DynamicResource AppTextPrimary}" FontSize="12" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding HealLogTab.Value}"
                                  OffContent="" OnContent="" VerticalAlignment="Center" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Combat Log Tab" Foreground="{DynamicResource AppTextPrimary}" FontSize="12" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding CombatLogTab.Value}"
                                  OffContent="" OnContent="" VerticalAlignment="Center" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Kill Zones Tab" Foreground="{DynamicResource AppTextPrimary}" FontSize="12" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding ZoneKillsTab.Value}"
                                  OffContent="" OnContent="" VerticalAlignment="Center" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Kill Heatmap Tab" Foreground="{DynamicResource AppTextPrimary}" FontSize="12" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding KillHeatmapTab.Value}"
                                  OffContent="" OnContent="" VerticalAlignment="Center" />
                </Grid>
                <Rectangle Fill="{DynamicResource AppBorderBrush}" Height="1" />
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Chat Log Path"
                                       Foreground="{DynamicResource AppTextPrimary}" FontSize="12" />
                            <TextBlock Text="Leave empty to auto-detect"
                                       Foreground="{DynamicResource AppTextMuted}" FontSize="10" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Browse"
                                Command="{Binding BrowseChatLogPathCommand}"
                                CommandParameter="{Binding $parent[Window].StorageProvider}"
                                Background="#FF3A3A4A" Foreground="{DynamicResource AppTextPrimary}"
                                Padding="8,4" CornerRadius="4" BorderThickness="0"
                                FontSize="11" VerticalAlignment="Center" Margin="6,0,0,0" />
                        <Button Grid.Column="2"
                                Content="✕"
                                Command="{Binding ClearChatLogPathCommand}"
                                IsVisible="{Binding CustomChatLogPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Background="Transparent" Foreground="{DynamicResource AppTextMuted}"
                                Padding="6,4" BorderThickness="0"
                                FontSize="11" VerticalAlignment="Center" Margin="2,0,0,0" />
                    </Grid>
                    <TextBox Text="{Binding CustomChatLogPath}"
                             Watermark="Auto-detected"
                             IsReadOnly="True"
                             FontSize="10"
                             Padding="6,4" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Watch error banner -->
        <Border Background="#CC8B0000"
                CornerRadius="8"
                Padding="12,8"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                Margin="10,10,10,0"
                IsVisible="{Binding WatchError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding WatchError, StringFormat='Watch error: {0}'}"
                           Foreground="White"
                           FontSize="13"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="✕"
                        Command="{Binding DismissWatchErrorCommand}"
                        Background="Transparent"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="8,4"
                        Margin="8,0,0,0"
                        FontSize="13" />
            </Grid>
        </Border>

        <!-- Screenshot toast -->
        <Border x:Name="ScreenshotToast"
                Background="#CC333333"
                CornerRadius="8"
                Padding="16,10"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,30"
                IsVisible="False"
                Opacity="0">
            <TextBlock Text="Screenshot copied to clipboard"
                       Foreground="White"
                       FontSize="14" />
        </Border>

    </Panel>
</Window>
