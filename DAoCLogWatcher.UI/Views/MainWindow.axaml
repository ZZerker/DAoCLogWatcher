<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DAoCLogWatcher.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:tabs="using:DAoCLogWatcher.UI.Views.Tabs"
        xmlns:viewcontrols="using:DAoCLogWatcher.UI.Views.Controls"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="DAoCLogWatcher.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/logo.ico"
        Title="{Binding SettingsPopup.AppVersion, StringFormat='DAoC Log Watcher {0}'}"
        Width="1535" Height="1268"
        Background="{DynamicResource AppWindowBackground}"
        Classes.highlight-multikills="{Binding HighlightMultiKills}"
        Classes.highlight-multihits="{Binding HighlightMultiHits}">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Window.highlight-multikills Border.multikill">
            <Setter Property="Background" Value="{DynamicResource AppMultiKillHighlightBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppWarning}" />
            <Setter Property="BorderThickness" Value="3,0,0,1" />
        </Style>
        <Style Selector="Window.highlight-multikills Border.multikill TextBlock.source-label">
            <Setter Property="Foreground" Value="{DynamicResource AppWarning}" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style Selector="Window.highlight-multihits Border.multihit">
            <Setter Property="Background" Value="{DynamicResource AppMultiHitHighlightBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppMultiHit}" />
            <Setter Property="BorderThickness" Value="3,0,0,1" />
        </Style>
    </Window.Styles>

    <Panel>
        <Grid RowDefinitions="Auto,*">
            <viewcontrols:AppToolbar Grid.Row="0" x:Name="Toolbar" />

            <Grid x:Name="MainContentGrid" Grid.Row="1" ColumnDefinitions="320,*" Margin="10,0,10,10">
                <viewcontrols:SummarySidebar Grid.Column="0" />

                <Border Grid.Column="1" Background="{DynamicResource AppPanelBackground}"
                        BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="8"
                        Padding="10" Margin="0,0,0,0">
                    <TabControl x:Name="MainTabControl">
                        <TabControl.Styles>
                            <Style Selector="TabControl">
                                <Setter Property="TabStripPlacement" Value="Top" />
                            </Style>
                            <Style Selector="TabItem">
                                <Setter Property="Padding" Value="16,10,16,9" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0,0,0,2" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Template">
                                    <ControlTemplate>
                                        <Border Name="PART_LayoutRoot"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter Name="PART_ContentPresenter"
                                                              Content="{TemplateBinding Header}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter>
                            </Style>
                            <Style Selector="TabItem:selected">
                                <Setter Property="BorderBrush" Value="{DynamicResource AppAccentCyan}" />
                            </Style>
                            <Style Selector="TabItem TextBlock.tab-label">
                                <Setter Property="Foreground" Value="#FF777777" />
                                <Setter Property="FontSize" Value="13" />
                                <Setter Property="FontWeight" Value="Normal" />
                            </Style>
                            <Style Selector="TabItem:selected TextBlock.tab-label">
                                <Setter Property="Foreground" Value="#FFFFFFFF" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Style>
                            <Style Selector="TabItem:pointerover:not(:selected) TextBlock.tab-label">
                                <Setter Property="Foreground" Value="#FFAAAAAA" />
                            </Style>
                            <Style Selector="TabItem TextBlock.tab-sublabel">
                                <Setter Property="Foreground" Value="#FF777777" />
                                <Setter Property="FontSize" Value="11" />
                            </Style>
                            <Style Selector="TabItem:selected TextBlock.tab-sublabel">
                                <Setter Property="Foreground" Value="{DynamicResource AppAccentCyan}" />
                            </Style>
                        </TabControl.Styles>

                        <TabItem IsVisible="{Binding DashboardTab.Value}">
                            <TabItem.Header>
                                <TextBlock Classes="tab-label" Text="Dashboard" />
                            </TabItem.Header>
                            <tabs:DashboardTabView />
                        </TabItem>

                        <TabItem IsVisible="{Binding RealmPointsTab.Value}">
                            <TabItem.Header>
                                <TextBlock Classes="tab-label" Text="Realm Points" />
                            </TabItem.Header>
                            <tabs:RealmPointsTabView />
                        </TabItem>

                        <TabItem IsVisible="{Binding CombatTab.Value}">
                            <TabItem.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Classes="tab-label" Text="Combat" />
                                    <TextBlock Classes="tab-sublabel" Text="Stats · Log" />
                                </StackPanel>
                            </TabItem.Header>
                            <tabs:CombatTabView />
                        </TabItem>

                        <TabItem IsVisible="{Binding HealLogTab.Value}">
                            <TabItem.Header>
                                <TextBlock Classes="tab-label" Text="Heals" />
                            </TabItem.Header>
                            <tabs:HealLogTabView />
                        </TabItem>

                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Spacing="2">
                                    <TextBlock Classes="tab-label" Text="Map" />
                                    <TextBlock Classes="tab-sublabel" Text="Zones · Heatmap" />
                                </StackPanel>
                            </TabItem.Header>
                            <tabs:MapTabView />
                        </TabItem>

                    </TabControl>
                </Border>
            </Grid>
        </Grid>

        <!-- Sidebar reopen strip (visible only when sidebar is collapsed) -->
        <Button IsVisible="{Binding !SettingsPopup.IsSidebarVisible}"
                Command="{Binding SettingsPopup.ToggleSidebarCommand}"
                Content="▶"
                HorizontalAlignment="Left" VerticalAlignment="Center"
                Margin="0"
                Background="#FF336655" Foreground="White"
                Padding="4,20" BorderThickness="0"
                CornerRadius="0,6,6,0"
                ToolTip.Tip="Show Summary" />

        <!-- Update available popup -->
        <Border IsVisible="{Binding IsUpdateAvailable}"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,30,30"
                Background="{DynamicResource AppCardBackground}"
                BorderBrush="{DynamicResource AppUpdate}" BorderThickness="1"
                CornerRadius="8" Padding="16,12"
                BoxShadow="0 4 20 0 #88000000">
            <StackPanel Spacing="10" Width="260">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Update Available" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{DynamicResource AppTextPrimary}" />
                        <TextBlock Text="{Binding UpdateVersionText}" FontSize="12"
                                   Foreground="{DynamicResource AppUpdate}" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="✕"
                            Classes="btn-ghost"
                            Command="{Binding DismissUpdateCommand}"
                            VerticalAlignment="Top" />
                </Grid>
                <TextBlock Text="{Binding UpdateError}" FontSize="11" TextWrapping="Wrap"
                           Foreground="{DynamicResource AppDanger}"
                           IsVisible="{Binding UpdateError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                <Button Content="Update"
                        Command="{Binding ApplyUpdateAndRestartCommand}"
                        Classes="btn-primary"
                        Background="{DynamicResource AppUpdate}"
                        HorizontalAlignment="Stretch" />
            </StackPanel>
        </Border>

        <!-- Custom time filter popup -->
        <Border IsVisible="{Binding TimeFilter.IsCustomPopupVisible}"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="340,55,0,0"
                Background="{DynamicResource AppCardBackground}"
                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="16,14"
                BoxShadow="0 4 20 0 #88000000">
            <StackPanel Spacing="12" Width="220">
                <TextBlock Text="Custom time window"
                           FontWeight="SemiBold" FontSize="13"
                           Foreground="{DynamicResource AppTextPrimary}" />
                <Grid ColumnDefinitions="*,12,*">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Hours" FontSize="11" Foreground="{DynamicResource AppTextMuted}" />
                        <NumericUpDown Value="{Binding TimeFilter.CustomInputHours}"
                                       Minimum="0" Maximum="9999"
                                       Increment="1" FormatString="0"
                                       ClipValueToMinMax="True" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                        <TextBlock Text="Minutes" FontSize="11" Foreground="{DynamicResource AppTextMuted}" />
                        <NumericUpDown Value="{Binding TimeFilter.CustomInputMinutes}"
                                       Minimum="0" Maximum="59"
                                       Increment="5" FormatString="0"
                                       ClipValueToMinMax="True" />
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Apply"
                            Command="{Binding TimeFilter.ApplyCustomFilterCommand}"
                            Classes="btn-primary"
                            Background="{DynamicResource AppAccentCyan}"
                            Foreground="#1A1A2E" />
                    <Button Content="Cancel"
                            Command="{Binding TimeFilter.CancelCustomFilterCommand}"
                            Classes="btn-secondary" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Send notification toast -->
        <Border IsVisible="{Binding SendNotification.IsVisible}"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,20,20"
                Background="#DD1E1E2E"
                BorderBrush="{DynamicResource AppAccentCyan}" BorderThickness="1"
                CornerRadius="8" Padding="14,10"
                BoxShadow="0 4 20 0 #88000000">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="2">
                    <TextBlock Text="{Binding SendNotification.Sender}"
                               Foreground="{DynamicResource AppAccentCyan}" FontWeight="SemiBold" FontSize="13" />
                    <TextBlock Text="{Binding SendNotification.Message}"
                               Foreground="{DynamicResource AppTextPrimary}" FontSize="12"
                               TextWrapping="Wrap" MaxWidth="300" />
                </StackPanel>
                <Button Grid.Column="1" Content="✕"
                        Classes="btn-ghost"
                        Command="{Binding SendNotification.DismissCommand}"
                        VerticalAlignment="Top" Margin="8,0,0,0" />
            </Grid>
        </Border>

        <!-- Settings popup -->
        <Border IsVisible="{Binding SettingsPopup.IsSettingsPopupVisible}"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,55,10,0"
                Background="{DynamicResource AppCardBackground}"
                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="16,14"
                BoxShadow="0 4 20 0 #88000000">
            <StackPanel Spacing="12" Width="300">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Settings"
                               FontWeight="SemiBold" FontSize="13"
                               Foreground="{DynamicResource AppTextPrimary}"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="✕"
                            Classes="btn-ghost"
                            Command="{Binding SettingsPopup.CloseSettingsPopupCommand}"
                            VerticalAlignment="Top" />
                </Grid>
                <Rectangle Fill="{DynamicResource AppBorderBrush}" Height="1" />
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Highlight Multi-Kills"
                                   Foreground="{DynamicResource AppTextPrimary}" FontSize="12" />
                        <TextBlock Text="Amber border on multi-kill RP entries"
                                   Foreground="{DynamicResource AppTextMuted}" FontSize="10" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1"
                                  IsChecked="{Binding HighlightMultiKills}"
                                  OffContent="" OnContent=""
                                  VerticalAlignment="Center" />
                </Grid>
                <Rectangle Fill="{DynamicResource AppBorderBrush}" Height="1" />
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Highlight AoE Multi-Hits"
                                   Foreground="{DynamicResource AppTextPrimary}" FontSize="12" />
                        <TextBlock Text="Purple border on AoE aggregate combat log entries"
                                   Foreground="{DynamicResource AppTextMuted}" FontSize="10" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1"
                                  IsChecked="{Binding HighlightMultiHits}"
                                  OffContent="" OnContent=""
                                  VerticalAlignment="Center" />
                </Grid>
                <Rectangle Fill="{DynamicResource AppBorderBrush}" Height="1" />
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Send Notifications"
                                   Foreground="{DynamicResource AppTextPrimary}" FontSize="12" />
                        <TextBlock Text="Show toast when a player sends a message"
                                   Foreground="{DynamicResource AppTextMuted}" FontSize="10" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1"
                                  IsChecked="{Binding ShowSendNotifications}"
                                  OffContent="" OnContent=""
                                  VerticalAlignment="Center" />
                </Grid>
                <Rectangle Fill="{DynamicResource AppBorderBrush}" Height="1" />
                <TextBlock Text="TABS" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource AppTextMuted}" />
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Dashboard Tab" Foreground="{DynamicResource AppTextPrimary}" FontSize="12" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding DashboardTab.Value}"
                                  OffContent="" OnContent="" VerticalAlignment="Center" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Realm Points Tab" Foreground="{DynamicResource AppTextPrimary}" FontSize="12" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding RealmPointsTab.Value}"
                                  OffContent="" OnContent="" VerticalAlignment="Center" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Combat Tab" Foreground="{DynamicResource AppTextPrimary}" FontSize="12" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding CombatTab.Value}"
                                  OffContent="" OnContent="" VerticalAlignment="Center" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Heals Tab" Foreground="{DynamicResource AppTextPrimary}" FontSize="12" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding HealLogTab.Value}"
                                  OffContent="" OnContent="" VerticalAlignment="Center" />
                </Grid>
                <Rectangle Fill="{DynamicResource AppBorderBrush}" Height="1" />
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Chat Log Path"
                                       Foreground="{DynamicResource AppTextPrimary}" FontSize="12" />
                            <TextBlock Text="Leave empty to auto-detect"
                                       Foreground="{DynamicResource AppTextMuted}" FontSize="10" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Browse"
                                Classes="btn-secondary"
                                Command="{Binding SettingsPopup.BrowseChatLogPathCommand}"
                                CommandParameter="{Binding $parent[Window].StorageProvider}"
                                Padding="10,5" FontSize="11"
                                VerticalAlignment="Center" Margin="6,0,0,0" />
                        <Button Grid.Column="2"
                                Content="✕"
                                Classes="btn-ghost"
                                Command="{Binding SettingsPopup.ClearChatLogPathCommand}"
                                IsVisible="{Binding SettingsPopup.CustomChatLogPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                FontSize="11" VerticalAlignment="Center" Margin="2,0,0,0" />
                    </Grid>
                    <TextBox Text="{Binding SettingsPopup.CustomChatLogPath}"
                             Watermark="Auto-detected"
                             IsReadOnly="True"
                             FontSize="10"
                             Padding="6,4" />
                </StackPanel>
                <Rectangle Fill="{DynamicResource AppBorderBrush}" Height="1" />
                <StackPanel Spacing="4">
                    <TextBlock Text="Diagnostics"
                               Foreground="{DynamicResource AppTextPrimary}" FontSize="12" />
                    <TextBlock Text="Errors are written to a daily log file (kept 7 days)"
                               Foreground="{DynamicResource AppTextMuted}" FontSize="10"
                               TextWrapping="Wrap" />
                    <Button Content="Open log folder"
                            Classes="btn-secondary"
                            Command="{Binding SettingsPopup.OpenLogFolderCommand}"
                            Padding="10,5" FontSize="11"
                            HorizontalAlignment="Left" Margin="0,2,0,0" />
                </StackPanel>
                <Rectangle Fill="{DynamicResource AppBorderBrush}" Height="1" />
                <TextBlock Text="{Binding SettingsPopup.AppVersion, StringFormat='DAoC Log Watcher {0}'}"
                           FontSize="10"
                           Foreground="{DynamicResource AppTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Watch error banner -->
        <Border Background="#CC8B0000"
                CornerRadius="8"
                Padding="12,8"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                Margin="10,10,10,0"
                IsVisible="{Binding WatchError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding WatchError, StringFormat='Watch error: {0}'}"
                           Foreground="White"
                           FontSize="13"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="✕"
                        Classes="btn-ghost"
                        Command="{Binding DismissWatchErrorCommand}"
                        Foreground="White"
                        Margin="8,0,0,0"
                        FontSize="13" />
            </Grid>
        </Border>

        <!-- Screenshot toast -->
        <Border x:Name="ScreenshotToast"
                Background="#CC333333"
                CornerRadius="8"
                Padding="16,10"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,30"
                IsVisible="False"
                Opacity="0">
            <TextBlock Text="Screenshot copied to clipboard"
                       Foreground="White"
                       FontSize="14" />
        </Border>

    </Panel>
</Window>