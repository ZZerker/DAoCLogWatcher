<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DAoCLogWatcher.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:scott="using:ScottPlot.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="DAoCLogWatcher.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/logo.ico"
        Title="DAoC Log Watcher"
        Width="1535" Height="1268"
        Background="{DynamicResource AppWindowBackground}">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Panel>
    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Background="{DynamicResource AppPanelBackground}" Padding="15" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Content="Open DAoC Log"
                        Command="{Binding OpenDaocLogCommand}"
                        Background="#FF007ACC"
                        Foreground="White"
                        Padding="12,8"
                        CornerRadius="6"
                        BorderThickness="0" />
                <Button Content="Open Log File"
                        Command="{Binding OpenFileCommand}"
                        CommandParameter="{Binding $parent[Window].StorageProvider}"
                        Background="#FF007ACC"
                        Foreground="White"
                        Padding="12,8"
                        CornerRadius="6"
                        BorderThickness="0" />
                <Button Content="Stop Watching"
                        Command="{Binding StopWatchingCommand}"
                        IsEnabled="{Binding IsWatching}"
                        Background="#FFDC3545"
                        Foreground="White"
                        Padding="12,8"
                        CornerRadius="6"
                        BorderThickness="0" />
                <Button Content="📷"
                        Click="OnScreenshotClick"
                        ToolTip.Tip="Copy screenshot to clipboard"
                        Background="#FF555566"
                        Foreground="White"
                        Padding="12,8"
                        CornerRadius="6"
                        BorderThickness="0" />
                <Button Content="{Binding ThemeIcon}"
                        Command="{Binding ToggleThemeCommand}"
                        Background="#FF555566"
                        Foreground="White"
                        Padding="12,8"
                        CornerRadius="6"
                        BorderThickness="0" />
                <ComboBox SelectedIndex="{Binding SelectedTimeFilterIndex}"
                          VerticalAlignment="Center"
                          Margin="20,0,0,0"
                          MinWidth="120">
                    <ComboBoxItem Content="All time" />
                    <ComboBoxItem Content="Last 1 week" />
                    <ComboBoxItem Content="Last 48h" />
                    <ComboBoxItem Content="Last 24h" />
                    <ComboBoxItem Content="Last 12h" />
                    <ComboBoxItem Content="Last 6h" />
                    <ComboBoxItem Content="Last 3h" />
                    <ComboBoxItem Content="Last 2h" />
                    <ComboBoxItem Content="Last 1h" />
                    <ComboBoxItem Content="Custom…" />
                </ComboBox>
                <TextBlock Text="{Binding CurrentFilePath}"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           Foreground="{DynamicResource AppTextMuted}"
                           FontSize="12" />
            </StackPanel>
        </Border>

        <Grid x:Name="MainContentGrid" Grid.Row="1" ColumnDefinitions="320,*" Margin="10,0,10,10">
            <Border Grid.Column="0" Background="{DynamicResource AppPanelBackground}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,10,0">
                <StackPanel Spacing="18">
                    <Grid>
                        <TextBlock Text="Summary" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" VerticalAlignment="Center" />
                        <Button Content="{Binding SidebarToggleIcon}" Command="{Binding ToggleSidebarCommand}"
                                HorizontalAlignment="Right" Background="Transparent"
                                Foreground="{DynamicResource AppTextMuted}" Padding="6,2" BorderThickness="0" FontSize="14" />
                    </Grid>

                    <Border Background="{DynamicResource AppCardBackground}" CornerRadius="6" Padding="15"
                            IsVisible="{Binding DetectedCharacterName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="CHARACTER" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource AppTextMuted}" />
                            <TextBlock Text="{Binding DetectedCharacterName}" FontSize="20" FontWeight="Bold" Foreground="#FF00D9FF" />
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="KILLS" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource AppTextMuted}" />
                                    <TextBlock Text="{Binding Kills}" FontSize="16" FontWeight="Bold" Foreground="#FF00D968" />
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="DEATHS" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource AppTextMuted}" />
                                    <TextBlock Text="{Binding Deaths}" FontSize="16" FontWeight="Bold" Foreground="#FFDC3545" />
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="K/D" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource AppTextMuted}" />
                                    <TextBlock Text="{Binding KdRatio, StringFormat='{}{0:F2}'}" FontSize="16" FontWeight="Bold" Foreground="#FFFFAA00" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- commented out until reimplementation -->
                    <!-- My Characters  --> 
                    <!-- <Border Background="{DynamicResource AppCardBackground}" CornerRadius="6" Padding="15" -->
                    <!--         IsVisible="{Binding HasCharacters}"> -->
                    <!--     <StackPanel Spacing="8"> -->
                    <!--         <TextBlock Text="MY CHARACTERS" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource AppTextMuted}" /> -->
                    <!--         <ItemsControl ItemsSource="{Binding CharacterKillStats}"> -->
                    <!--             <ItemsControl.ItemTemplate> -->
                    <!--                 <DataTemplate> -->
                    <!--                     <Grid ColumnDefinitions="*,Auto" Margin="0,3,0,0"> -->
                    <!--                         <TextBlock Grid.Column="0" Text="{Binding Name}" -->
                    <!--                                    Foreground="{DynamicResource AppTextSecondary}" FontSize="13" /> -->
                    <!--                         <TextBlock Grid.Column="1" -->
                    <!--                                    Text="{Binding KillCount, StringFormat='{}{0} kills'}" -->
                    <!--                                    Foreground="#FF00D968" FontWeight="Bold" FontSize="13" /> -->
                    <!--                     </Grid> -->
                    <!--                 </DataTemplate> -->
                    <!--             </ItemsControl.ItemTemplate> -->
                    <!--         </ItemsControl> -->
                    <!--     </StackPanel> -->
                    <!-- </Border> -->

                    <!-- <Border Height="1" Background="{DynamicResource AppBorderBrush}" -->
                    <!--         IsVisible="{Binding HasCharacters}" /> -->

                    <Border Background="{DynamicResource AppCardBackground}" CornerRadius="6" Padding="15">
                        <StackPanel Spacing="10">
                            <StackPanel Spacing="8">
                                <TextBlock Text="TOTAL REALM POINTS" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource AppTextMuted}" />
                                <TextBlock Text="{Binding Summary.TotalRealmPoints}" FontSize="32" FontWeight="Bold" Foreground="#FF00D9FF" />
                            </StackPanel>
                            <StackPanel Spacing="5">
                                <TextBlock Text="RPs PER HOUR" FontWeight="SemiBold" FontSize="10" Foreground="{DynamicResource AppTextDim}" />
                                <TextBlock Text="{Binding Summary.RpsPerHour, StringFormat='{}{0:F0} RP/h'}" FontSize="18" FontWeight="SemiBold" Foreground="#FFAA88FF" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Height="1" Background="{DynamicResource AppBorderBrush}" />

                    <Grid>
                        <TextBlock Text="ABSOLUTE NUMBERS" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource AppTextMuted}" VerticalAlignment="Center" />
                        <Button Content="{Binding AbsoluteNumbersToggleIcon}" Command="{Binding ToggleAbsoluteNumbersCommand}"
                                HorizontalAlignment="Right" Background="Transparent"
                                Foreground="{DynamicResource AppTextMuted}" Padding="6,2" BorderThickness="0" FontSize="14" />
                    </Grid>
                    <StackPanel Spacing="6" IsVisible="{Binding IsAbsoluteNumbersVisible}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Player Kills:" MinWidth="130" Foreground="{DynamicResource AppTextSecondary}" />
                            <TextBlock Text="{Binding Summary.PlayerKills}" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Campaign Quests:" MinWidth="130" Foreground="{DynamicResource AppTextSecondary}" />
                            <TextBlock Text="{Binding Summary.CampaignQuests}" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Ticks:" MinWidth="130" Foreground="{DynamicResource AppTextSecondary}" />
                            <TextBlock Text="{Binding Summary.Ticks}" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Siege:" MinWidth="130" Foreground="{DynamicResource AppTextSecondary}" />
                            <TextBlock Text="{Binding Summary.Siege}" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Assault Order:" MinWidth="130" Foreground="{DynamicResource AppTextSecondary}" />
                            <TextBlock Text="{Binding Summary.AssaultOrder}" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Support Ticks:" MinWidth="130" Foreground="{DynamicResource AppTextSecondary}" />
                            <TextBlock Text="{Binding Summary.SupportActivity}" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Relic Capture:" MinWidth="130" Foreground="{DynamicResource AppTextSecondary}" />
                            <TextBlock Text="{Binding Summary.RelicCapture}" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Timed Missions:" MinWidth="130" Foreground="{DynamicResource AppTextSecondary}" />
                            <TextBlock Text="{Binding Summary.TimedMissions}" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Misc:" MinWidth="130" Foreground="{DynamicResource AppTextSecondary}" />
                            <TextBlock Text="{Binding Summary.Misc}" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" />
                        </StackPanel>
                    </StackPanel>

                    <Border Height="1" Background="{DynamicResource AppBorderBrush}" />

                    <Grid>
                        <TextBlock Text="ABSOLUTE RPs" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource AppTextMuted}" VerticalAlignment="Center" />
                        <Button Content="{Binding AbsoluteRpsToggleIcon}" Command="{Binding ToggleAbsoluteRpsCommand}"
                                HorizontalAlignment="Right" Background="Transparent"
                                Foreground="{DynamicResource AppTextMuted}" Padding="6,2" BorderThickness="0" FontSize="14" />
                    </Grid>
                    <StackPanel Spacing="6" IsVisible="{Binding IsAbsoluteRpsVisible}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Player Kills:" MinWidth="130" Foreground="{DynamicResource AppTextSecondary}" />
                            <TextBlock Text="{Binding Summary.PlayerKillsRP}" FontWeight="Bold" Foreground="#FF00D968" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Campaign Quests:" MinWidth="130" Foreground="{DynamicResource AppTextSecondary}" />
                            <TextBlock Text="{Binding Summary.CampaignQuestsRP}" FontWeight="Bold" Foreground="#FF00D968" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Ticks:" MinWidth="130" Foreground="{DynamicResource AppTextSecondary}" />
                            <TextBlock Text="{Binding Summary.TicksRP}" FontWeight="Bold" Foreground="#FF00D968" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Siege:" MinWidth="130" Foreground="{DynamicResource AppTextSecondary}" />
                            <TextBlock Text="{Binding Summary.SiegeRP}" FontWeight="Bold" Foreground="#FF00D968" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Assault Order:" MinWidth="130" Foreground="{DynamicResource AppTextSecondary}" />
                            <TextBlock Text="{Binding Summary.AssaultOrderRP}" FontWeight="Bold" Foreground="#FF00D968" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Support Ticks:" MinWidth="130" Foreground="{DynamicResource AppTextSecondary}" />
                            <TextBlock Text="{Binding Summary.SupportActivityRP}" FontWeight="Bold" Foreground="#FF00D968" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Relic Capture:" MinWidth="130" Foreground="{DynamicResource AppTextSecondary}" />
                            <TextBlock Text="{Binding Summary.RelicCaptureRP}" FontWeight="Bold" Foreground="#FF00D968" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Timed Missions:" MinWidth="130" Foreground="{DynamicResource AppTextSecondary}" />
                            <TextBlock Text="{Binding Summary.TimedMissionsRP}" FontWeight="Bold" Foreground="#FF00D968" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Misc:" MinWidth="130" Foreground="{DynamicResource AppTextSecondary}" />
                            <TextBlock Text="{Binding Summary.MiscRP}" FontWeight="Bold" Foreground="#FF00D968" />
                        </StackPanel>
                    </StackPanel>

                    <Border Height="1" Background="{DynamicResource AppBorderBrush}" />

                    <Grid>
                        <TextBlock Text="PERCENTAGES" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource AppTextMuted}" VerticalAlignment="Center" />
                        <Button Content="{Binding PercentagesToggleIcon}" Command="{Binding TogglePercentagesCommand}"
                                HorizontalAlignment="Right" Background="Transparent"
                                Foreground="{DynamicResource AppTextMuted}" Padding="6,2" BorderThickness="0" FontSize="14" />
                    </Grid>
                    <StackPanel Spacing="6" IsVisible="{Binding IsPercentagesVisible}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Player Kills:" MinWidth="130" Foreground="{DynamicResource AppTextSecondary}" />
                            <TextBlock Text="{Binding Summary.PlayerKillsPercentage, StringFormat='{}{0:F1}%'}" FontWeight="Bold" Foreground="#FFFFAA00" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Campaign Quests:" MinWidth="130" Foreground="{DynamicResource AppTextSecondary}" />
                            <TextBlock Text="{Binding Summary.CampaignQuestsPercentage, StringFormat='{}{0:F1}%'}" FontWeight="Bold" Foreground="#FFFFAA00" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Ticks:" MinWidth="130" Foreground="{DynamicResource AppTextSecondary}" />
                            <TextBlock Text="{Binding Summary.TicksPercentage, StringFormat='{}{0:F1}%'}" FontWeight="Bold" Foreground="#FFFFAA00" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Siege:" MinWidth="130" Foreground="{DynamicResource AppTextSecondary}" />
                            <TextBlock Text="{Binding Summary.SiegePercentage, StringFormat='{}{0:F1}%'}" FontWeight="Bold" Foreground="#FFFFAA00" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Assault Order:" MinWidth="130" Foreground="{DynamicResource AppTextSecondary}" />
                            <TextBlock Text="{Binding Summary.AssaultOrderPercentage, StringFormat='{}{0:F1}%'}" FontWeight="Bold" Foreground="#FFFFAA00" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Support Ticks:" MinWidth="130" Foreground="{DynamicResource AppTextSecondary}" />
                            <TextBlock Text="{Binding Summary.SupportActivityPercentage, StringFormat='{}{0:F1}%'}" FontWeight="Bold" Foreground="#FFFFAA00" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Relic Capture:" MinWidth="130" Foreground="{DynamicResource AppTextSecondary}" />
                            <TextBlock Text="{Binding Summary.RelicCapturePercentage, StringFormat='{}{0:F1}%'}" FontWeight="Bold" Foreground="#FFFFAA00" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Timed Missions:" MinWidth="130" Foreground="{DynamicResource AppTextSecondary}" />
                            <TextBlock Text="{Binding Summary.TimedMissionsPercentage, StringFormat='{}{0:F1}%'}" FontWeight="Bold" Foreground="#FFFFAA00" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Misc:" MinWidth="130" Foreground="{DynamicResource AppTextSecondary}" />
                            <TextBlock Text="{Binding Summary.MiscPercentage, StringFormat='{}{0:F1}%'}" FontWeight="Bold" Foreground="#FFFFAA00" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="{DynamicResource AppPanelBackground}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,0">
                <TabControl>

                    <!-- ── Realm Points tab ── -->
                    <TabItem Header="Realm Points">
                        <Grid RowDefinitions="*,Auto" Margin="10,10,10,0">
                            <DockPanel Grid.Row="0">
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,15">
                                    <TextBlock Text="Realm Point Log" FontSize="22" FontWeight="Bold" Margin="0,0,15,0" Foreground="{DynamicResource AppTextPrimary}" />
                                    <TextBlock Text="{Binding LogEntries.Count, StringFormat='({0} entries)'}" FontSize="14" VerticalAlignment="Center" Foreground="{DynamicResource AppTextMuted}" />
                                </StackPanel>

                                <ScrollViewer Background="{DynamicResource AppCardBackground}" CornerRadius="6" Padding="10"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{Binding LogEntries}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{DynamicResource AppRowBorder}" BorderThickness="0,0,0,1" Padding="10,8" Background="Transparent">
                                                    <Grid ColumnDefinitions="Auto,Auto,Auto,*">
                                                        <TextBlock Grid.Column="0" Text="{Binding Timestamp}"
                                                                   Foreground="{DynamicResource AppTextMuted}"
                                                                   FontFamily="Consolas,Courier New,monospace"
                                                                   FontSize="13"
                                                                   Margin="0,0,20,0"
                                                                   MinWidth="80" />
                                                        <TextBlock Grid.Column="1" Text="{Binding Points, StringFormat='+{0} RP'}"
                                                                   Foreground="#FF00D968"
                                                                   FontWeight="Bold"
                                                                   FontSize="13"
                                                                   Margin="0,0,20,0"
                                                                   MinWidth="90" />
                                                        <TextBlock Grid.Column="2" Text="{Binding Source}"
                                                                   Foreground="#FF00D9FF"
                                                                   FontSize="13"
                                                                   Margin="0,0,20,0"
                                                                   MinWidth="150" />
                                                        <TextBlock Grid.Column="3" Text="{Binding Details}"
                                                                   Foreground="{DynamicResource AppTextSecondary}"
                                                                   FontSize="13"
                                                                   TextWrapping="Wrap" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>

                            <Border Grid.Row="1" Background="{DynamicResource AppCardBackground}" CornerRadius="6" Padding="15" Margin="0,15,0,0">
                                <StackPanel Spacing="8">

                                    <!-- RP/h chart -->
                                    <Grid>
                                        <TextBlock Text="RP/h – Rolling 1-Hour Window" FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AppTextPrimary}" VerticalAlignment="Center" />
                                        <Button Content="{Binding RpsChartToggleIcon}" Command="{Binding ToggleRpsChartCommand}"
                                                HorizontalAlignment="Right" Background="Transparent"
                                                Foreground="{DynamicResource AppTextMuted}" Padding="6,2" BorderThickness="0" FontSize="14" />
                                    </Grid>
                                    <scott:AvaPlot x:Name="RpsHourlyChart" Height="180" IsVisible="{Binding IsRpsChartVisible}" />

                                    <Border Height="1" Background="{DynamicResource AppBorderBrush}" Margin="0,4,0,4" />

                                    <!-- Total RPs chart -->
                                    <Grid>
                                        <TextBlock Text="Realm Points Over Time" FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AppTextPrimary}" VerticalAlignment="Center" />
                                        <Button Content="{Binding RpChartToggleIcon}" Command="{Binding ToggleRpChartCommand}"
                                                HorizontalAlignment="Right" Background="Transparent"
                                                Foreground="{DynamicResource AppTextMuted}" Padding="6,2" BorderThickness="0" FontSize="14" />
                                    </Grid>
                                    <scott:AvaPlot x:Name="RpChart" Height="180" IsVisible="{Binding IsRpChartVisible}" />

                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- ── Combat tab ── -->
                    <TabItem Header="Combat">
                        <ScrollViewer Margin="10,10,10,0" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Spacing="18">

                                <!-- Damage dealt -->
                                <Border Background="{DynamicResource AppCardBackground}" CornerRadius="6" Padding="15">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="DAMAGE DEALT" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource AppTextMuted}" />
                                        <StackPanel Orientation="Horizontal" Spacing="30">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="TOTAL" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource AppTextMuted}" />
                                                <TextBlock Text="{Binding CombatSummary.TotalDamageDealt}" FontSize="28" FontWeight="Bold" Foreground="#FFFF6644" />
                                            </StackPanel>
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="HITS" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource AppTextMuted}" />
                                                <TextBlock Text="{Binding CombatSummary.HitCount}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" />
                                            </StackPanel>
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="AVG / HIT" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource AppTextMuted}" />
                                                <TextBlock Text="{Binding CombatSummary.AvgDamagePerHit}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimary}" />
                                            </StackPanel>
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="CRITS" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource AppTextMuted}" />
                                                <TextBlock Text="{Binding CombatSummary.CritCount}" FontSize="28" FontWeight="Bold" Foreground="#FFFFCC44" />
                                            </StackPanel>
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="CRIT RATE" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource AppTextMuted}" />
                                                <TextBlock Text="{Binding CombatSummary.CritRate, StringFormat='{}{0:F1}%'}" FontSize="28" FontWeight="Bold" Foreground="#FFFFCC44" />
                                            </StackPanel>
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="ABSORBED" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource AppTextMuted}" />
                                                <TextBlock Text="{Binding CombatSummary.TotalAbsorbed}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AppTextMuted}" />
                                            </StackPanel>
                                        </StackPanel>
                                        <Border Height="1" Background="{DynamicResource AppBorderBrush}" Margin="0,4,0,4" />
                                        <TextBlock Text="AVG DAMAGE BY ATTACK TYPE" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource AppTextMuted}" />
                                        <scott:AvaPlot x:Name="AvgDmgBySpellChart" Height="200" />
                                    </StackPanel>
                                </Border>

                                <!-- Damage taken from attackers -->
                                <Border Background="{DynamicResource AppCardBackground}" CornerRadius="6" Padding="15">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="DAMAGE TAKEN FROM" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource AppTextMuted}" />
                                        <scott:AvaPlot x:Name="DmgByTargetChart" Height="200" />
                                    </StackPanel>
                                </Border>

                                <!-- Damage taken -->
                                <Border Background="{DynamicResource AppCardBackground}" CornerRadius="6" Padding="15">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="DAMAGE TAKEN" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource AppTextMuted}" />
                                        <TextBlock Text="{Binding CombatSummary.TotalDamageTaken}" FontSize="28" FontWeight="Bold" Foreground="#FFDC3545" />
                                    </StackPanel>
                                </Border>

                                <!-- Heals received -->
                                <Border Background="{DynamicResource AppCardBackground}" CornerRadius="6" Padding="15">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="HEALS RECEIVED" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource AppTextMuted}" />
                                        <TextBlock Text="{Binding CombatSummary.TotalHealsReceived}" FontSize="28" FontWeight="Bold" Foreground="#FF00D968" />
                                        <Border Height="1" Background="{DynamicResource AppBorderBrush}" Margin="0,4,0,4" />
                                        <TextBlock Text="BY HEALER" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource AppTextMuted}" />
                                        <scott:AvaPlot x:Name="HealsByHealerChart" Height="200" />
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                </TabControl>
            </Border>
        </Grid>
    </Grid>

    <!-- Sidebar reopen strip (visible only when sidebar is collapsed) -->
    <Button IsVisible="{Binding !IsSidebarVisible}"
            Command="{Binding ToggleSidebarCommand}"
            Content="▶"
            HorizontalAlignment="Left" VerticalAlignment="Center"
            Margin="0"
            Background="#FF336655" Foreground="White"
            Padding="4,20" BorderThickness="0"
            CornerRadius="0,6,6,0"
            ToolTip.Tip="Show Summary" />

    <!-- Update available popup -->
    <Border IsVisible="{Binding IsUpdateAvailable}"
            HorizontalAlignment="Right" VerticalAlignment="Bottom"
            Margin="0,0,30,30"
            Background="{DynamicResource AppCardBackground}"
            BorderBrush="#FF28A745" BorderThickness="1"
            CornerRadius="8" Padding="16,12"
            BoxShadow="0 4 20 0 #88000000">
        <StackPanel Spacing="10" Width="260">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="2">
                    <TextBlock Text="Update Available" FontWeight="SemiBold" FontSize="13"
                               Foreground="{DynamicResource AppTextPrimary}" />
                    <TextBlock Text="{Binding UpdateVersionText}" FontSize="12"
                               Foreground="#FF28A745" />
                </StackPanel>
                <Button Grid.Column="1" Content="✕"
                        Command="{Binding DismissUpdateCommand}"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource AppTextMuted}"
                        Padding="6,2" FontSize="12"
                        VerticalAlignment="Top" />
            </Grid>
            <Button Content="Update"
                    Command="{Binding ApplyUpdateAndRestartCommand}"
                    Background="#FF28A745" Foreground="White"
                    Padding="10,7" CornerRadius="5" BorderThickness="0"
                    HorizontalAlignment="Stretch" />
        </StackPanel>
    </Border>

    <!-- Custom time filter popup -->
    <Border IsVisible="{Binding IsCustomPopupVisible}"
            HorizontalAlignment="Left" VerticalAlignment="Top"
            Margin="340,55,0,0"
            Background="{DynamicResource AppCardBackground}"
            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
            CornerRadius="8" Padding="16,14"
            BoxShadow="0 4 20 0 #88000000">
        <StackPanel Spacing="12" Width="220">
            <TextBlock Text="Custom time window"
                       FontWeight="SemiBold" FontSize="13"
                       Foreground="{DynamicResource AppTextPrimary}" />
            <Grid ColumnDefinitions="*,12,*">
                <StackPanel Spacing="4">
                    <TextBlock Text="Hours" FontSize="11" Foreground="{DynamicResource AppTextMuted}" />
                    <NumericUpDown Value="{Binding CustomInputHours}"
                                   Minimum="0" Maximum="9999"
                                   Increment="1" FormatString="0"
                                   ClipValueToMinMax="True" />
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Text="Minutes" FontSize="11" Foreground="{DynamicResource AppTextMuted}" />
                    <NumericUpDown Value="{Binding CustomInputMinutes}"
                                   Minimum="0" Maximum="59"
                                   Increment="5" FormatString="0"
                                   ClipValueToMinMax="True" />
                </StackPanel>
            </Grid>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Apply"
                        Command="{Binding ApplyCustomFilterCommand}"
                        Background="#FF00D9FF" Foreground="#FF1A1A2E"
                        Padding="14,7" CornerRadius="5" BorderThickness="0"
                        FontWeight="SemiBold" />
                <Button Content="Cancel"
                        Command="{Binding CancelCustomFilterCommand}"
                        Background="Transparent"
                        Foreground="{DynamicResource AppTextMuted}"
                        Padding="10,7" CornerRadius="5" BorderThickness="1"
                        BorderBrush="{DynamicResource AppBorderBrush}" />
            </StackPanel>
        </StackPanel>
    </Border>

    </Panel>
</Window>
