<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DAoCLogWatcher.UI.ViewModels"
             xmlns:scott="using:ScottPlot.Avalonia"
             x:Class="DAoCLogWatcher.UI.Views.Tabs.CombatTabView"
             x:DataType="vm:MainWindowViewModel">

    <ScrollViewer Margin="10,10,10,0" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="18">

            <Border Background="{DynamicResource AppCardBackground}" CornerRadius="6" Padding="15">
                <StackPanel Spacing="10">
                    <TextBlock Text="DAMAGE DEALT" FontWeight="SemiBold" FontSize="11"
                               Foreground="{DynamicResource AppTextMuted}" />
                    <StackPanel Orientation="Horizontal" Spacing="30">
                        <StackPanel Spacing="2">
                            <TextBlock Text="TOTAL" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextMuted}" />
                            <TextBlock Text="{Binding CombatSummary.TotalDamageDealt}"
                                       FontSize="28" FontWeight="Bold" Foreground="#FFFF6644" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="HITS" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextMuted}" />
                            <TextBlock Text="{Binding CombatSummary.HitCount}" FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AppTextPrimary}" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="AVG / HIT" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextMuted}" />
                            <TextBlock Text="{Binding CombatSummary.AvgDamagePerHit}"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource AppTextPrimary}" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="CRITS" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextMuted}" />
                            <TextBlock Text="{Binding CombatSummary.CritCount}" FontSize="28"
                                       FontWeight="Bold" Foreground="#FFFFCC44" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="CRIT RATE" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextMuted}" />
                            <TextBlock
                                Text="{Binding CombatSummary.CritRate, StringFormat='{}{0:F1}%'}"
                                FontSize="28" FontWeight="Bold" Foreground="#FFFFCC44" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="ABSORBED" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextMuted}" />
                            <TextBlock Text="{Binding CombatSummary.TotalAbsorbed}"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource AppTextMuted}" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="30">
                        <StackPanel Spacing="2">
                            <TextBlock Text="MELEE MISS" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextMuted}" />
                            <TextBlock
                                Text="{Binding CombatSummary.MeleeMissRate, StringFormat='{}{0:F1}%'}"
                                FontSize="22" FontWeight="Bold"
                                Foreground="{DynamicResource AppTextPrimary}" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="SPELL RESIST" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextMuted}" />
                            <TextBlock
                                Text="{Binding CombatSummary.SpellResistRate, StringFormat='{}{0:F1}%'}"
                                FontSize="22" FontWeight="Bold"
                                Foreground="{DynamicResource AppTextPrimary}" />
                        </StackPanel>
                    </StackPanel>
                    <Grid>
                        <TextBlock Text="AVG DAMAGE BY ATTACK TYPE" FontWeight="SemiBold"
                                   FontSize="11" Foreground="{DynamicResource AppTextMuted}"
                                   VerticalAlignment="Center" />
                        <Button Content="{Binding AvgDmgChart.Icon}"
                                Command="{Binding AvgDmgChart.ToggleCommand}"
                                HorizontalAlignment="Right" Background="Transparent"
                                Foreground="{DynamicResource AppTextMuted}" Padding="6,2"
                                BorderThickness="0" FontSize="14" />
                    </Grid>
                    <scott:AvaPlot x:Name="AvgDmgBySpellChart" Height="200"
                                   IsVisible="{Binding AvgDmgChart.Value}" />
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource AppCardBackground}" CornerRadius="6" Padding="15">
                <StackPanel Spacing="10">
                    <TextBlock Text="DAMAGE TAKEN" FontWeight="SemiBold" FontSize="11"
                               Foreground="{DynamicResource AppTextMuted}" />
                    <TextBlock Text="{Binding CombatSummary.TotalDamageTaken}" FontSize="28"
                               FontWeight="Bold" Foreground="#FFDC3545" />
                    <Grid>
                        <TextBlock Text="BY ATTACKER" FontWeight="SemiBold" FontSize="11"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   VerticalAlignment="Center" />
                        <Button Content="{Binding DmgByAttackerChart.Icon}"
                                Command="{Binding DmgByAttackerChart.ToggleCommand}"
                                HorizontalAlignment="Right" Background="Transparent"
                                Foreground="{DynamicResource AppTextMuted}" Padding="6,2"
                                BorderThickness="0" FontSize="14" />
                    </Grid>
                    <scott:AvaPlot x:Name="DmgByTargetChart" Height="200"
                                   IsVisible="{Binding DmgByAttackerChart.Value}" />
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource AppCardBackground}" CornerRadius="6" Padding="15">
                <StackPanel Spacing="10">
                    <TextBlock Text="HEALS RECEIVED" FontWeight="SemiBold" FontSize="11"
                               Foreground="{DynamicResource AppTextMuted}" />
                    <TextBlock Text="{Binding CombatSummary.TotalHealsReceived}" FontSize="28"
                               FontWeight="Bold" Foreground="#FF00D968" />
                    <Grid>
                        <TextBlock Text="BY HEALER" FontWeight="SemiBold" FontSize="11"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   VerticalAlignment="Center" />
                        <Button Content="{Binding HealsByHealerChart.Icon}"
                                Command="{Binding HealsByHealerChart.ToggleCommand}"
                                HorizontalAlignment="Right" Background="Transparent"
                                Foreground="{DynamicResource AppTextMuted}" Padding="6,2"
                                BorderThickness="0" FontSize="14" />
                    </Grid>
                    <scott:AvaPlot x:Name="HealsByHealerChartCombat" Height="200"
                                   IsVisible="{Binding HealsByHealerChart.Value}" />
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource AppCardBackground}" CornerRadius="6" Padding="15">
                <StackPanel Spacing="10">
                    <TextBlock Text="HEALS DONE" FontWeight="SemiBold" FontSize="11"
                               Foreground="{DynamicResource AppTextMuted}" />
                    <TextBlock Text="{Binding CombatSummary.TotalHealingDone}" FontSize="28"
                               FontWeight="Bold" Foreground="#FF00D968" />
                    <Grid>
                        <TextBlock Text="BY TARGET" FontWeight="SemiBold" FontSize="11"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   VerticalAlignment="Center" />
                        <Button Content="{Binding HealsByTargetChart.Icon}"
                                Command="{Binding HealsByTargetChart.ToggleCommand}"
                                HorizontalAlignment="Right" Background="Transparent"
                                Foreground="{DynamicResource AppTextMuted}" Padding="6,2"
                                BorderThickness="0" FontSize="14" />
                    </Grid>
                    <scott:AvaPlot x:Name="HealsByTargetChartCombat" Height="200"
                                   IsVisible="{Binding HealsByTargetChart.Value}" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
