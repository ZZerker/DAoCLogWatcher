<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DAoCLogWatcher.UI.ViewModels"
             xmlns:scott="using:ScottPlot.Avalonia"
             xmlns:controls="using:DAoCLogWatcher.UI.Controls"
             x:Class="DAoCLogWatcher.UI.Views.Tabs.KillHeatmapTabView"
             x:DataType="vm:MainWindowViewModel">

    <Grid RowDefinitions="Auto,*" Margin="10,10,10,0">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
            <StackPanel Spacing="4">
                <TextBlock Text="Kill Activity Heatmap" FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource AppTextPrimary}" />
                <TextBlock
                    Text="Hot zones in the active window — color intensity shows relative kill density"
                    FontSize="12" Foreground="{DynamicResource AppTextMuted}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10"
                        VerticalAlignment="Center">
                <TextBlock
                    Text="{Binding RecentZoneKillCount, StringFormat='Total: {0} kills'}"
                    Foreground="{DynamicResource AppTextSecondary}" FontSize="13"
                    VerticalAlignment="Center" />
                <ComboBox Width="140"
                          ItemsSource="{Binding ZoneKillWindowOptions}"
                          SelectedItem="{Binding SelectedZoneKillWindow}"
                          FontSize="13">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </Grid>
        <controls:AspectRatioPanel Grid.Row="1" Ratio="0.91667"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Margin="0,2,0,0">
            <scott:AvaPlot x:Name="KillHeatmapPlot" />
        </controls:AspectRatioPanel>
    </Grid>
</UserControl>
