<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DAoCLogWatcher.UI.ViewModels"
             x:Class="DAoCLogWatcher.UI.Views.Tabs.CombatLogTabView"
             x:DataType="vm:MainWindowViewModel">

    <Grid RowDefinitions="*" Margin="10,10,10,0">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,15" Spacing="10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Combat Log" FontSize="22" FontWeight="Bold"
                               Margin="0,0,15,0"
                               Foreground="{DynamicResource AppTextPrimary}" />
                    <TextBlock
                        Text="{Binding CombatLog.Filtered.Count, StringFormat='({0} entries)'}"
                        FontSize="14" VerticalAlignment="Center"
                        Foreground="{DynamicResource AppTextMuted}" />
                </StackPanel>
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox Grid.Column="0"
                             Text="{Binding CombatLog.FilterText}"
                             Watermark="Filter by target or source…"
                             FontSize="13" />
                    <Button Grid.Column="1"
                            Content="✕"
                            Command="{Binding CombatLog.ClearFilterCommand}"
                            IsVisible="{Binding CombatLog.FilterText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Margin="6,0,0,0"
                            Padding="8,4"
                            FontSize="13" />
                </Grid>
            </StackPanel>

            <ScrollViewer Background="{DynamicResource AppCardBackground}" CornerRadius="6"
                          Padding="10"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding CombatLog.Filtered}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource AppRowBorder}"
                                    BorderThickness="0,0,0,1" Padding="10,8"
                                    Background="Transparent"
                                    Classes.multihit="{Binding IsMultiHit}">
                                <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*">
                                    <TextBlock Grid.Column="0" Text="{Binding Timestamp}"
                                               Foreground="{DynamicResource AppTextMuted}"
                                               FontFamily="Consolas,Courier New,monospace"
                                               FontSize="13"
                                               Margin="0,0,20,0"
                                               MinWidth="80" />
                                    <Grid Grid.Column="1" MinWidth="55" Margin="0,0,20,0">
                                        <TextBlock Text="AoE" FontSize="13" FontWeight="Bold"
                                                   IsVisible="{Binding IsMultiHit}"
                                                   Foreground="#FFCC44FF" />
                                        <TextBlock Text="Dealt" FontSize="13" FontWeight="Bold"
                                                   IsVisible="{Binding ShowDealtLabel}"
                                                   Foreground="#FF00D968" />
                                        <TextBlock Text="Taken" FontSize="13" FontWeight="Bold"
                                                   IsVisible="{Binding !IsDealt}"
                                                   Foreground="#FFDC3545" />
                                    </Grid>
                                    <TextBlock Grid.Column="2" Text="{Binding TotalDamage}"
                                               FontWeight="Bold"
                                               FontSize="13"
                                               Margin="0,0,20,0"
                                               MinWidth="70"
                                               Foreground="#FFFF6644" />
                                    <TextBlock Grid.Column="3" Text="{Binding Source}"
                                               FontSize="13"
                                               Margin="0,0,20,0"
                                               MinWidth="100"
                                               Foreground="#FF00D9FF" />
                                    <TextBlock Grid.Column="4" Text="{Binding Opponent}"
                                               Foreground="{DynamicResource AppTextSecondary}"
                                               FontSize="13" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>