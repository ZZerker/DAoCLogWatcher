<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DAoCLogWatcher.UI.ViewModels"
             xmlns:scott="using:ScottPlot.Avalonia"
             x:Class="DAoCLogWatcher.UI.Views.Tabs.KillZonesTabView"
             x:DataType="vm:MainWindowViewModel">

    <Grid RowDefinitions="Auto,*,Auto" Margin="10,10,10,0">
        <StackPanel Spacing="10" Grid.Row="0">
            <TextBlock Text="Current Kill Zones" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource AppTextPrimary}" />
            <TextBlock Text="Zones with more than one recent kill in the active window"
                       Foreground="{DynamicResource AppTextMuted}" FontSize="12" />
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Window:" FontSize="13"
                           Foreground="{DynamicResource AppTextSecondary}"
                           VerticalAlignment="Center" />
                <ComboBox Width="140"
                          ItemsSource="{Binding ZoneKillWindowOptions}"
                          SelectedItem="{Binding SelectedZoneKillWindow}"
                          FontSize="13">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
            <TextBlock
                Text="{Binding RecentZoneKillCount, StringFormat='Total recent kills: {0}'}"
                Foreground="{DynamicResource AppTextSecondary}" FontSize="13" />
        </StackPanel>

        <Border Grid.Row="2" Background="{DynamicResource AppCardBackground}" CornerRadius="6"
                Padding="15" Margin="0,10,0,0">
            <StackPanel Spacing="8">
                <Grid>
                    <TextBlock Text="Global Activity" FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextPrimary}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="Kills per point in time over the current window"
                               FontSize="12"
                               Foreground="{DynamicResource AppTextMuted}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center" />
                </Grid>
                <scott:AvaPlot x:Name="GlobalActivityChart" Height="180" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="{DynamicResource AppCardBackground}"
                CornerRadius="6" Padding="10" Margin="0,10,0,0">
            <ItemsControl ItemsSource="{Binding ZoneKills}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{DynamicResource AppRowBorder}"
                                BorderThickness="0,0,0,1" Padding="10,8">
                            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="12">
                                <TextBlock Text="{Binding Zone}"
                                           FontSize="13"
                                           Foreground="{DynamicResource AppTextPrimary}"
                                           VerticalAlignment="Center" />
                                <Border Width="12" Height="12"
                                        Background="{Binding HeatColor}"
                                        CornerRadius="6"
                                        VerticalAlignment="Center"
                                        Margin="8,0" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Percentage, StringFormat='{}{0:F2}%'}"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource AppTextSecondary}"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="3"
                                           Text="{Binding KillCount, StringFormat='{}{0} kills'}"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource AppTextSecondary}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </Grid>
</UserControl>
