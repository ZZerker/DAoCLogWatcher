<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DAoCLogWatcher.UI.ViewModels"
             xmlns:controls="using:DAoCLogWatcher.UI.Views.Controls"
             x:Class="DAoCLogWatcher.UI.Views.Tabs.HealLogTabView"
             x:DataType="vm:MainWindowViewModel">

    <Grid RowDefinitions="*" Margin="10,10,10,0">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,15" Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <controls:StatTile Label="HEALS DONE" Value="{Binding CombatSummary.TotalHealingDone}"
                                       ValueColor="{DynamicResource AppPositive}" />
                    <controls:StatTile Label="HEALS RECEIVED" Value="{Binding CombatSummary.TotalHealsReceived}"
                                       ValueColor="{DynamicResource AppPositive}" />
                    <controls:StatTile Label="CRIT RATE"
                                       Value="{Binding CombatSummary.HealCritRate, StringFormat='{}{0:F1}%'}"
                                       ValueColor="{DynamicResource AppCrit}" />
                    <controls:StatTile Label="PEOPLE HEALED" Value="{Binding CombatSummary.UniqueHealTargetCount}"
                                       ValueColor="{DynamicResource AppTextPrimary}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Heal Log" FontSize="22" FontWeight="Bold"
                               Margin="0,0,15,0"
                               Foreground="{DynamicResource AppTextPrimary}" />
                    <TextBlock
                        Text="{Binding CombatStats.HealLog.Filtered.Count, StringFormat='({0} entries)'}"
                        FontSize="14" VerticalAlignment="Center"
                        Foreground="{DynamicResource AppTextMuted}" />
                </StackPanel>
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox Grid.Column="0"
                             Text="{Binding CombatStats.HealLog.FilterText}"
                             Watermark="Filter by healer or direction…"
                             FontSize="13" />
                    <Button Grid.Column="1"
                            Content="✕"
                            Classes="btn-ghost"
                            Command="{Binding CombatStats.HealLog.ClearFilterCommand}"
                            IsVisible="{Binding CombatStats.HealLog.FilterText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Margin="6,0,0,0" />
                </Grid>

                <Border Background="{DynamicResource AppCardBackground}"
                        BorderBrush="{DynamicResource AppRowBorder}" BorderThickness="1"
                        CornerRadius="8" Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Heals Done" FontWeight="Bold" FontSize="14"
                                   Foreground="{DynamicResource AppTextPrimary}" />
                        <StackPanel Orientation="Horizontal" Spacing="30">
                            <controls:StatNumber Label="TOTAL" Value="{Binding CombatSummary.TotalHealingDone}"
                                                 ValueColor="{DynamicResource AppPositive}" />
                            <controls:StatNumber Label="CRITS" Value="{Binding CombatSummary.HealCritCount}"
                                                 ValueColor="{DynamicResource AppCrit}" />
                            <controls:StatNumber Label="CRIT RATE"
                                                 Value="{Binding CombatSummary.HealCritRate, StringFormat='{}{0:F1}%'}"
                                                 ValueColor="{DynamicResource AppCrit}" />
                        </StackPanel>
                        <Grid>
                            <TextBlock Text="By Target" FontWeight="Bold" FontSize="14"
                                       Foreground="{DynamicResource AppTextPrimary}"
                                       VerticalAlignment="Center" />
                            <Button Content="{Binding HealsByTargetChart.Icon}"
                                    Command="{Binding HealsByTargetChart.ToggleCommand}"
                                    Classes="btn-ghost"
                                    HorizontalAlignment="Right" FontSize="14" />
                        </Grid>
                        <ItemsControl ItemsSource="{Binding CombatStats.HealsByTargetStats}"
                                      IsVisible="{Binding HealsByTargetChart.Value}"
                                      ItemTemplate="{StaticResource HealStatRowTemplate}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border DockPanel.Dock="Bottom" Background="{DynamicResource AppCardBackground}"
                    BorderBrush="{DynamicResource AppRowBorder}" BorderThickness="1"
                    CornerRadius="8" Padding="16" Margin="0,10,0,0">
                <StackPanel Spacing="10">
                    <TextBlock Text="Heals Received" FontWeight="Bold" FontSize="14"
                               Foreground="{DynamicResource AppTextPrimary}" />
                    <TextBlock Text="{Binding CombatSummary.TotalHealsReceived}"
                               FontSize="28"
                               FontWeight="Bold" Foreground="{DynamicResource AppPositive}" />
                    <Grid>
                        <TextBlock Text="By Healer" FontWeight="Bold" FontSize="14"
                                   Foreground="{DynamicResource AppTextPrimary}"
                                   VerticalAlignment="Center" />
                        <Button Content="{Binding HealsByHealerChart.Icon}"
                                Command="{Binding HealsByHealerChart.ToggleCommand}"
                                Classes="btn-ghost"
                                HorizontalAlignment="Right" FontSize="14" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding CombatStats.HealsByHealerStats}"
                                  IsVisible="{Binding HealsByHealerChart.Value}"
                                  ItemTemplate="{StaticResource HealStatRowTemplate}" />
                </StackPanel>
            </Border>

            <ScrollViewer Background="{DynamicResource AppCardBackground}" CornerRadius="6"
                          Padding="10" Margin="0,10,0,10"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding CombatStats.HealLog.Filtered}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource AppRowBorder}"
                                    BorderThickness="0,0,0,1" Padding="10,8"
                                    Background="Transparent">
                                <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*">
                                    <TextBlock Grid.Column="0" Text="{Binding Timestamp}"
                                               Foreground="{DynamicResource AppTextMuted}"
                                               FontFamily="Consolas,Courier New,monospace"
                                               FontSize="13"
                                               Margin="0,0,20,0"
                                               MinWidth="80" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding HitPoints, StringFormat='+{0} HP'}"
                                               FontWeight="Bold"
                                               FontSize="13"
                                               Margin="0,0,20,0"
                                               MinWidth="90"
                                               Foreground="{DynamicResource AppPositive}" />
                                    <Border Grid.Column="2"
                                            Background="#21FFCC44"
                                            BorderBrush="#7FFFCC44"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="6,1"
                                            Margin="0,0,10,0"
                                            VerticalAlignment="Center"
                                            IsVisible="{Binding IsCrit}">
                                        <TextBlock Text="CRIT"
                                                   FontSize="9"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource AppCrit}" />
                                    </Border>
                                    <TextBlock Grid.Column="3" Text="{Binding DirectionLabel}"
                                               FontSize="13"
                                               Margin="0,0,20,0"
                                               MinWidth="80"
                                               Foreground="{DynamicResource AppAccentCyan}" />
                                    <controls:PlayerNameControl Grid.Column="4"
                                                                PlayerName="{Binding Who}"
                                                                NameForeground="{DynamicResource AppTextSecondary}"
                                                                NameFontSize="13" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>